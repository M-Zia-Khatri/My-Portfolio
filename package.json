{
  "name": "my-profolio",
  "privcdate": true,
  "version": "1.0.0",
  "description": "This is My Portfolio",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter client --filter server dev",
    "build": "pnpm -r build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "prepare": "husky install"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,md,mdx}": [
      "biome check --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/M-Zia-Khatri/My-Portfolio.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/M-Zia-Khatri/My-Portfolio/issues"
  },
  "homepage": "https://github.com/M-Zia-Khatri/My-Portfolio#readme",
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^8.0.0",
    "lint-staged": "^16.4.0"
  }
}
