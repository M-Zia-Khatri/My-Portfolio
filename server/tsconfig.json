{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,

    /* CRITICAL CHANGES BELOW */
    "noEmit": false, // Set to false so 'tsc' actually generates the /dist folder
    "allowImportingTsExtensions": false // Set to false if you want 'tsc' to emit JS files
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "generated"]
}
